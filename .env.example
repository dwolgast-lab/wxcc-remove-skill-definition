# ============================================================
# wxcc-remove-skill-definition — configuration template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# ----------------------------------------------------------
# WxCC tenant settings
# ----------------------------------------------------------

# Your Webex Contact Center organization ID (required)
WXCC_ORG_ID=your-org-id-here

# WxCC datacenter region (default: us1)
# Valid values: us1, us2, eu1, eu2, anz1, jp1, ca1, in1
WXCC_REGION=us1

# ----------------------------------------------------------
# Authentication — choose ONE of the two options below
# ----------------------------------------------------------

# OPTION A: Personal Bearer Token
#   - Get yours at https://developer.webex.com (click your avatar → Copy token)
#   - Expires every ~12 hours; fine for occasional / one-off use
#   - If set, this takes precedence over OPTION B
WXCC_BEARER_TOKEN=

# OPTION B: Service App (OAuth2 Client Credentials) — recommended for client use
#   - Create a Service App at https://developer.webex.com/my-apps
#   - Required scopes: cjp:config  cjp:config_write
#   - A Webex/Control Hub admin must authorize the app for the org
#     (Control Hub → Apps → Service Apps → Authorize)
#   - Tokens auto-refresh; no manual intervention needed
WXCC_CLIENT_ID=
WXCC_CLIENT_SECRET=
